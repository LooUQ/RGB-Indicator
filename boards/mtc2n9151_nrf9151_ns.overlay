
//#include "../mtc2n9151_pin-disable.overlay"

/ {
    pins {
        compatible = "gpio-leds";

        hxctrl: pin_0 {
            gpios = <&gpio0 29 GPIO_ACTIVE_HIGH>;
        };

    };
    keys {
        compatible = "gpio-keys";
        hxrqst: pin_1 {
            gpios = <&gpio0 28 GPIO_ACTIVE_HIGH>;
        };
    };

};

